<!DOCTYPE params SYSTEM "../../../../../src/libs/tgf/params.dtd">
<params name="mpa1-ffr" type="template" mode="mw">
      <!-- Car parameters >>> -->
	<section name="Front Wing">
		<attnum name="angle" unit="deg" min="0" max="29" val="20"/>
	</section>

	<section name="Rear Wing">
	    	<attnum name="angle" unit="deg" min="0" max="29" val="14"/>
	</section>

	<section name="Gearbox">
		<section name="gears">
			<section name="r">
				<attnum name="ratio" min="-3" max="0" val="-2"/>
			</section>
			<section name="1">
				<attnum name="ratio" min="0" max="5" val="5.000"/>
			</section>
			<section name="2">
				<attnum name="ratio" min="0" max="5" val="3.054"/>
			</section>
			<section name="3">
				<attnum name="ratio" min="0" max="5" val="1.784"/>
			</section>
			<section name="4">
				<attnum name="ratio" min="0" max="5" val="1.315"/>
			</section>
			<section name="5">
				<attnum name="ratio" min="0" max="5" val="1.132"/>
			</section>
			<section name="6">
				<attnum name="ratio" min="0" max="5" val="1.000"/>
			</section>
		</section>
	</section>

	<section name="Brake System">
		<attnum name="front-rear brake repartition" min="0.3" max="0.7" val="0.52"/>
		<attnum name="max pressure" unit="kPa" min="5000" max="65000" val="45000"/>
		<attnum name="brake corr lr" min="0" max="0.5" val="0.28"/>
		<attnum name="brake corr fr" min="0" max="0.5" val="0.14"/>
	</section>

	  <section name="Front Right Wheel">
    <attnum name="ride height" unit="mm" min="50" max="100" val="80"/>
    <attnum name="toe" unit="deg" min="-5" max="5" val="0.1"/>
    <attnum name="camber" unit="deg" min="-5" max="0" val="-3"/>
  </section>

  <section name="Front Left Wheel">
    <attnum name="ride height" unit="mm" min="50" max="100" val="80"/>
    <attnum name="toe" unit="deg" min="-5" max="5" val="-0.1"/>
    <attnum name="camber" unit="deg" min="-5" max="0" val="-3"/>
  </section>

  <section name="Rear Right Wheel">
    <attnum name="ride height" unit="mm" min="50" max="100" val="80"/>
    <attnum name="toe" unit="deg" min="-5" max="5" val="0"/>
    <attnum name="camber" unit="deg" min="-5" max="0" val="-1"/>
  </section>

  <section name="Rear Left Wheel">
    <attnum name="ride height" unit="mm" min="50" max="100" val="80"/>
    <attnum name="toe" unit="deg" min="-5" max="5" val="0"/>
    <attnum name="camber" unit="deg" min="-5" max="0" val="-1"/>
  </section>

  <section name="Front Anti-Roll Bar">
    <attnum name="spring" unit="kN/m" min="0" max="50" val="8.0"/>
  </section>

  <section name="Rear Anti-Roll Bar">
    <attnum name="spring" unit="kN/m" min="0" max="50" val="36.0"/>
  </section>

  <section name="Front Right Suspension">
    <attnum name="spring" unit="kN/m" min="100" max="410" val="195"/>
    <attnum name="suspension course" unit="m" min="0" max="0.2" val="0.16"/>
    <attnum name="bellcrank" min="1" max="1" val="1"/>
    <attnum name="packers" unit="mm" min="0" max="10" val="0"/>
    <attnum name="slow bump" unit="kN/m/s" min="1" max="70" val="4.2"/>
    <attnum name="slow rebound" unit="kN/m/s" min="1" max="70" val="4.1"/>
    <attnum name="fast bump" unit="kN/m/s" min="1" max="70" val="2.25"/>
    <attnum name="fast rebound" unit="kN/m/s" min="1" max="70" val="2.50"/>
  </section>

  <section name="Front Left Suspension">
    <attnum name="spring" unit="kN/m" min="100" max="410" val="195"/>
    <attnum name="suspension course" unit="m" min="0" max="0.2" val="0.16"/>
    <attnum name="bellcrank" min="1" max="1" val="1"/>
    <attnum name="packers" unit="mm" min="0" max="10" val="0"/>
    <attnum name="slow bump" unit="kN/m/s" min="1" max="70" val="4.2"/>
    <attnum name="slow rebound" unit="kN/m/s" min="1" max="70" val="4.1"/>
    <attnum name="fast bump" unit="kN/m/s" min="1" max="70" val="2.25"/>
    <attnum name="fast rebound" unit="kN/m/s" min="1" max="70" val="2.50"/>
  </section>

  <section name="Rear Right Suspension">
    <attnum name="spring" unit="kN/m" min="100" max="410" val="145.0"/>
    <attnum name="suspension course" unit="m" min="0" max="0.2" val="0.16"/>
    <attnum name="bellcrank" min="1" max="1" val="1"/>
    <attnum name="packers" unit="mm" min="0" max="10" val="0"/>
    <attnum name="slow bump" unit="kN/m/s" min="1" max="70" val="3.8"/>
    <attnum name="slow rebound" unit="kN/m/s" min="1" max="70" val="4.4"/>
    <attnum name="fast bump" unit="kN/m/s" min="1" max="70" val="2.4"/>
    <attnum name="fast rebound" unit="kN/m/s" min="1" max="70" val="2.8"/>
  </section>

  <section name="Rear Left Suspension">
    <attnum name="spring" unit="kN/m" min="100" max="410" val="145.0"/>
    <attnum name="suspension course" unit="m" min="0" max="0.2" val="0.16"/>
    <attnum name="bellcrank" min="1" max="1" val="1"/>
    <attnum name="packers" unit="mm" min="0" max="10" val="0"/>
    <attnum name="slow bump" unit="kN/m/s" min="1" max="70" val="3.8"/>
    <attnum name="slow rebound" unit="kN/m/s" min="1" max="70" val="4.4"/>
    <attnum name="fast bump" unit="kN/m/s" min="1" max="70" val="2.4"/>
    <attnum name="fast rebound" unit="kN/m/s" min="1" max="70" val="2.8"/>
  </section>

  <section name="private">
    <attnum name="speedfactor" val="1.15"/>
    <attnum name="brakeforcefactor" val="1.0"/>
    <attnum name="brakeforcemin" val="0.25"/>
    <attnum name="bumpspeedfactor" val="3.0"/>
    <attnum name="fuelpermeter" val="0.001"/>
    <attnum name="fuelweightfactor" val="1.0"/>
    <attnum name="pitdamage" val="5000"/>
    <attnum name="pitentrymargin" val="200.0"/>
    <attnum name="pitentryspeed" val="25.0"/>
    <attnum name="pitexitspeed" val="25.0"/>
    <attnum name="targetfactor" val="0.3"/>
    <attnum name="targetwalldist" val="0.0"/>
    <attnum name="tractioncontrol" val="1"/>
    <!-- Race line ClothoidPath -->
    <attnum name="maxleft" val="10.0"/>
    <attnum name="maxright" val="10.0"/>
    <attnum name="margininside" val="1.0"/>
    <attnum name="marginoutside" val="1.5"/>
    <attnum name="clothoidfactor" val="1.005"/>
    <attnum name="seglen" val="3.0"/>
  </section>
</params>
