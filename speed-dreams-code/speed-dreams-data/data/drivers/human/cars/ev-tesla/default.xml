<?xml version="1.0" encoding="iso-8859-1"?>
<!DOCTYPE params SYSTEM "../../../src/libs/tgf/params.dtd">
<params name="ev-tesla" type="template" mode="mw">
	<section name="Front Wing">
		<attnum name="angle" unit="deg" val="0"/>
	</section>
	<section name="Rear Wing">
		<attnum name="angle" unit="deg" val="0"/>
	</section>
	<section name="Rear Differential">
		<attstr name="type" in="SPOOL,FREE,LIMITED SLIP" val="LIMITED SLIP"/>
		<attnum name="ratio" val="4.1"/>
	</section>
	<section name="Brake System">
		<attnum name="front-rear brake repartition" val="0.62"/>
		<attnum name="max pressure" unit="kPa" val="10000"/>
	</section>
	<section name="Front Anti-Roll Bar">
		<attnum name="spring" unit="N/m" val="15000"/>
		<attnum name="suspension course" unit="m" val="0.02"/>
		<attnum name="bellcrank" val="1.0"/>
	</section>
	<section name="Rear Anti-Roll Bar">
		<attnum name="spring" unit="N/m" val="10000"/>
		<attnum name="suspension course" unit="m" val="0.02"/>
		<attnum name="bellcrank" val="1.0"/>
	</section>
	<section name="Front Right Wheel">
		<attnum name="ride height" unit="mm" val="120"/>
		<attnum name="toe" unit="deg" val="0.1"/>
		<attnum name="camber" unit="deg" val="0"/>
	</section>
	<section name="Front Left Wheel">
		<attnum name="ride height" unit="mm" val="120"/>
		<attnum name="toe" unit="deg" val="-0.1"/>
		<attnum name="camber" unit="deg" val="0"/>
	</section>
	<section name="Rear Right Wheel">
		<attnum name="ride height" unit="mm" val="120"/>
		<attnum name="toe" unit="deg" val="0"/>
		<attnum name="camber" unit="deg" val="0"/>
	</section>
	<section name="Rear Left Wheel">
		<attnum name="ride height" unit="mm" val="120"/>
		<attnum name="toe" unit="deg" val="0"/>
		<attnum name="camber" unit="deg" val="0"/>
	</section>
</params>
