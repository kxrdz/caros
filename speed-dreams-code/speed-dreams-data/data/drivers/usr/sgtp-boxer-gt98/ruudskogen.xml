<!DOCTYPE params SYSTEM "../../../../src/libs/tgf/params.dtd">

<params name="sgtp-boxer-gt98">
	<section name="Rear Wing">
		<attnum name="angle" unit="deg" min="5" max="24" val="19"/>
	</section>

	<section name="Front Anti-Roll Bar">
		<attnum name="spring" unit="kN/m" min="0" max="250" val="45"/>
	</section>

	<section name="Rear Anti-Roll Bar">
		<attnum name="spring" unit="kN/m" min="0" max="50" val="5"/>
	</section>
	<section name="Front Right Suspension">
	    <attstr name="suspension type" val="Wishbone"/>
		<attnum name="spring" min="100" max="410" unit="kN/m" val="130"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0" max="70" val="8"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0" max="70" val="16"/>
		<attnum name="fast bump" unit="kN/m/s" min="0" max="70" val="4"/>
		<attnum name="fast rebound" unit="kN/m/s" min="0" max="70" val="8"/>
		<attnum name="bump limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
		<attnum name="rebound limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
	</section>

	<section name="Front Left Suspension">
	    <attstr name="suspension type" val="Wishbone"/>
		<attnum name="spring" min="100" max="410" unit="kN/m" val="130"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0" max="70" val="8"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0" max="70" val="16"/>
		<attnum name="fast bump" unit="kN/m/s" min="0" max="70" val="4"/>
		<attnum name="fast rebound" unit="kN/m/s" min="0" max="70" val="8"/>
		<attnum name="bump limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
		<attnum name="rebound limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
	</section>

	<section name="Rear Right Suspension">
	    <attstr name="suspension type" val="Wishbone"/>
		<attnum name="spring" min="100" max="410" unit="kN/m" val="105"/>
		<attnum name="suspension course" unit="m" min="0" max="0.28" val="0.1"/>
		<attnum name="bellcrank" val="1.0"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0" max="70" val="7.5"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0" max="70" val="15"/>
		<attnum name="fast bump" unit="kN/m/s" min="0" max="70" val="3.75"/>
		<attnum name="fast rebound" unit="kN/m/s" min="0" max="70" val="7.5"/>
		<attnum name="bump limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
		<attnum name="rebound limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
	</section>

	<section name="Rear Left Suspension">
	    <attstr name="suspension type" val="Wishbone"/>
		<attnum name="spring" min="100" max="410" unit="kN/m" val="105"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0" max="70" val="7.5"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0" max="70" val="15"/>
		<attnum name="fast bump" unit="kN/m/s" min="0" max="70" val="3.75"/>
		<attnum name="fast rebound" unit="kN/m/s" min="0" max="70" val="7.5"/>
		<attnum name="bump limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
		<attnum name="rebound limit velocity" unit="m/s" min="0.1" max="0.3" val="0.2"/>
	</section>

  <section name="private">
    <!-- Others -->
    <attnum name="test line" min="0" max="2" val="0"/> <!-- test line: 1 left, 2 right -->
    <attnum name="message on" min="0" max="1" val="1"/>
    <attnum name="data log on" min="0" max="1" val="1"/>

    <attnum name="ABS slip" val="14.0"/>
	<attnum name="TCL side slip" val="25.0"/>
	<attnum name="TCL side slip qualy" val="40.0"/>
	<attnum name="TCL side slip factor" val="0.03"/>
    <attnum name="brake mu factor" val="0.675"/>
    <attnum name="LR mu scale" val="0.90"/>
    <attnum name="mu scale" val="0.95"/>
    <attnum name="brakepressrace" val="35000"/>
    <attnum name="brakepressnorm" val="35000"/>
    <attnum name="bump speed factor" val="1000.0"/>
    <attnum name="fuel per meter" val="0.0007"/>
	<attnum name="fuel weight factor" val="1.0"/>
	<attnum name="tire wear per meter" val="0.00001"/>
	<attnum name="Aggression Mult" val="0.010"/>
	<!--attnum name="max fuel" val="63"/-->

    <attnum name="pitdamage" val="5000"/>
    <attnum name="pitentrymargin" val="100.0"/>
    <attnum name="pitentryspeed" val="50.0"/>
    <attnum name="pitexitspeed" val="50.0"/>
    <attnum name="pittest" val="0"/>

    <attnum name="targetfactor" val="0.32"/>
    <attnum name="targetwalldist" val="0.0"/>
	<attnum name="lookahead" val="28.0"/>
	<attnum name="hottemp" val="115.0"/>
    <!-- Race line ClothoidPath -->
    <attnum name="maxleft" val="10.0"/>
    <attnum name="maxright" val="10.0"/>
    <attnum name="clothoidfactor" val="1.013"/>
    <attnum name="seglen" val="4.0"/>
	<attnum name="vmaxk" val="0.00183"/>
  </section>

</params>
