<!DOCTYPE params SYSTEM "../../../../src/libs/tgf/params.dtd">

<params name="mpa11-murasama">
  	<section name="Front Wing">
    	<attnum name="angle" unit="deg" min="0" max="12" val="12.0"/>
  	</section>

  	<section name="Rear Wing">
    	<attnum name="angle" unit="deg" min="0" max="17" val="10.5"/>
  	</section>

	<section name="Gearbox">
    	<section name="gears">
      		<section name="r">
        		<attnum name="ratio" min="-3" max="0" val="-2"/>
      		</section>

      		<section name="1">
        		<attnum name="ratio" min="0" max="5" val="2.6"/>
      		</section>

      		<section name="2">
        		<attnum name="ratio" min="0" max="5" val="1.82"/>
      		</section>

      		<section name="3">
        		<attnum name="ratio" min="0" max="5" val="1.426"/>
      		</section>

      		<section name="4">
        		<attnum name="ratio" min="0" max="5" val="0.950"/>
      		</section>

      		<section name="5">
        		<attnum name="ratio" min="0" max="5" val="0.808"/>
      		</section>

      		<section name="6">
        		<attnum name="ratio" min="0" max="5" val="0.730"/>
      		</section>
    	</section>
  	</section>

  <section name="private">
    <!-- Others -->
    <attnum name="test line" min="0" max="2" val="0"/> <!-- test line: 1 left, 2 right -->
    <attnum name="message on" min="0" max="1" val="0"/>
    <attnum name="data log on" min="0" max="1" val="0"/>

    <attnum name="ABS slip" val="14.0"/>
	<attnum name="TCL side slip" val="25.0"/>
	<attnum name="TCL side slip qualy" val="40.0"/>
	<attnum name="TCL side slip factor" val="0.03"/>
    <attnum name="brake mu factor" val="0.90"/>
    <attnum name="LR mu scale" val="0.90"/>
    <attnum name="mu scale" val="0.90"/>
    <attnum name="brakepressrace" val="21000"/>
    <attnum name="brakepressnorm" val="21000"/>
    <attnum name="bump speed factor" val="1000.0"/>
    <attnum name="fuel per meter" val="0.0007"/>
	<attnum name="fuel weight factor" val="1.0"/>
	<attnum name="tire wear per meter" val="0.00001"/>
	<!--attnum name="max fuel" val="63"/-->

    <attnum name="pitdamage" val="5000"/>
    <attnum name="pitentrymargin" val="150.0"/>
    <attnum name="pitentryspeed" val="50.0"/>
    <attnum name="pitexitspeed" val="50.0"/>
    <attnum name="pittest" val="0"/>

    <attnum name="targetfactor" val="0.32"/>
    <attnum name="targetwalldist" val="0.1"/>
	<attnum name="lookahead" val="14.0"/>
	<attnum name="hottemp" val="115.0"/>
    <!-- Race line ClothoidPath -->
    <attnum name="maxleft" val="10.0"/>
    <attnum name="maxright" val="10.0"/>
    <attnum name="clothoidfactor" val="1.013"/>
    <attnum name="seglen" val="4.0"/>
	<attnum name="vmaxk" val="0.00183"/>
  </section>

</params>
