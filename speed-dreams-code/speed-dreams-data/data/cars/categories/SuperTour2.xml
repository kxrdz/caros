<!DOCTYPE params SYSTEM "../../../../src/libs/tgf/params.dtd">

<params name="SuperTour2" type="template">
	<!-- Restricted Features -->
	<section name="Features">
		<!-- Mandatory Features -->
		<attstr name="shifting aero coordinate" in="yes,no" val="yes"/>
		<attstr name="fixed low speed grip" in="yes,no" val="yes"/>
		<attstr name="realistic gear change" in="yes,no" val="yes"/>
		<attstr name="realistic rev limiter" in="yes,no" val="yes"/>
		<attstr name="tire temperature and degradation" in="yes,no" val="yes"/>
		<attstr name="fixed wheel force" in="yes,no" val="yes"/>
		<attstr name="enable cliftlimit" in="yes,no" val="yes"/>
		<!-- Optional Features -->
		<attstr name="enable abs" in="yes,no" val="yes"/>
		<attstr name="enable tcl" in="yes,no" val="yes"/>
		<attstr name="enable esp" in="yes,no" val="yes"/>
	</section>

	<section name="Car">
		<!-- category -->
		<attstr name="category" val="SuperTour2"/>
		<!-- Body dimensions -->
		<attnum name="body length" unit="m" min="4.2" max="7.00" val="4.5"/>
		<attnum name="body width" unit="m" min=".3" max="3" val="2.0"/>
		<attnum name="body height" unit="m" min="0.8" max="2" val="1.0"/>

		<!-- collision bounding box -->
		<attnum name="overall length" unit="m" min="0.3" max="6.00" val="4.00"/>
		<attnum name="overall width" unit="m" min="1" max="3" val="1.908"/>

		<attnum name="mass" unit="kg" min="975.0" max="2000" val="975.0"/>
		<attnum name="GC height" unit="m" min="-0.3" max="0.5" val="0.30"/>

		<!-- weight bias -->
		<attnum name="front-rear weight repartition" min="0.2" max="0.8" val="0.7"/>
		<attnum name="front right-left weight repartition" min="0.5" max="0.5" val="0.5"/>
		<attnum name="rear right-left weight repartition" min="0.5" max="0.5" val="0.5"/>

		<!-- used for inertia, indicates the good mass centering (lower values) -->
		<attnum name="mass repartition coefficient" min="0.2" max="1.0" val="0.75"/>
		<attnum name="fuel tank" unit="l" min="5.0" max="100.0" val="100.0"/>
		<attnum name="initial fuel" unit="l" min="1.0" max="100.0" val="80.0"/>

	</section>

	<section name="Aerodynamics">
		<attnum name="Cx" min="0.20" max="1.0" val="0.38"/>
		<attnum name="front area" unit="m2" min="0.8" max="3.0" val="2.0"/>
		<!-- Total Clift limited by feature -->
		<attnum name="front Clift" min="0.0" max="0.6" val="0.3"/>
		<attnum name="rear Clift" min="0.0" max="0.6" val="0.3"/>
	</section>

	<section name="Front Wing">
		<attnum name="area" unit="m2" min="0" max="1.0" val="0.30"/>
		<attnum name="angle" unit="deg" min="0.0" max="30.0" val="6.0"/>
	</section>

	<section name="Rear Wing">
		<attnum name="area" unit="m2" min="0" max="1.0" val="0.30"/>
		<attnum name="angle" unit="deg" min="0.0" max="30.0" val="6.0"/>
		<!-- Position has to within the collision bounding box -->
	</section>

	<section name="Engine">
		<attnum name="capacity" unit="l" min="2.0" max="2.0" val="2.0"/>
		<attnum name="cylinders" min="4" max="6" val="4"/>
		<attstr name="shape" in="v,l,h,w" val="l"/>
		<attstr name="position" in="front,front-mid,mid,rear-mid,rear," val="front"/>

		<attnum name="revs maxi" unit="rpm" min="4000" max="8500" val="8500"/>
		<attnum name="revs limiter" unit="rpm" min="3000" max="8500" val="8500"/>
		<attnum name="tickover" unit="rpm" min="500" max="10000" val="1500"/>
		<attnum name="fuel cons factor" min="1.0" max="2.0" val="1.0"/>

		<!-- Thoses values aren't redefined in car specs-->
		<attnum name="torque def step" unit="rpm" min="500" max="1000" val="1000"/>
		<attnum name="inertia" unit="kg.m2" min="0.05" max="0.3" val="0.2"/>

		<!-- Absolute delimiter values -->
		<attnum name="torque min" unit="N.m" val="0.0"/>
		<attnum name="torque max" unit="N.m" val="2000.0"/>
		<attnum name="revs maxi min" unit="rpm" val="1000"/>
		<attnum name="revs maxi max" unit="rpm" val="8500"/>

		<!-- TCL cannot/can reduce throttle -->
		<attnum name="enable tcl" min="0" max="1" val="1"/>

		<!-- Values can be redefined in car specs -->
		<!-- (min can be increase, max can be decrease, val can be modified) -->

		<!--torque definition-->
		<section name="data points">
			<section name="1">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="1000.0" val="200.0"/>
			<section name="2">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="1500.0" val="200.0"/>
			</section>
			<section name="3">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="2000.0" val="200"/>
			</section>
			<section name="4">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="2500.0" val="200"/>
			</section>
			<section name="5">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="3000.0" val="200"/>
			</section>
			<section name="6">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="3500.0" val="200"/>
			</section>
			<section name="7">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="4000.0" val="200.0"/>
			</section>
			<section name="8">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="4500.0" val="200.0"/>
			</section>
			<section name="9">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="5000.0" val="200.0"/>
			</section>
			<section name="10">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="5500.0" val="200.0"/>
			</section>
			<section name="11">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="6000.0" val="200.0"/>
			</section>
			<section name="12">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="6500.0" val="200.0"/>
			</section>
			<section name="13">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="7000.0" val="250.0"/>
			</section>
			<section name="14">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="7500.0" val="250.0"/>
			</section>
			<section name="15">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="8000.0" val="250.0"/>
			</section>
			<section name="16">
				<attnum name="rpm" unit="rpm" min="0" max="20000" val="0"/>
				<attnum name="Tq" unit="N.m" min="0.0" max="8500.0" val="200.0"/>
			</section>
		</section>
	</section>
  </section>

  <section name="Clutch">
	<!-- Pressure plate -->
	<attnum name="inertia" unit="kg.m2" min="0.1" max="0.5" val="0.10"/>
  </section>

  <!-- To allow the car types to use different numbers of gears
	   the default ration of the gears has to be 0 -->
  <section name="Gearbox">
		<attnum name="shift time" min="0.015" max="0.5" val="0.1" unit="s"/>
		<section name="gears">
			<section name="r">
				<attnum name="ratio" min="-5" max="0" val="-3.0"/>
				<attnum name="inertia" val="0.0037"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.957"/>
			</section>

			<section name="1">
				<attnum name="ratio" min="0" max="5" val="2.0"/>
				<attnum name="inertia" val="0.003"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.9496"/>
			</section>

			<section name="2">
				<attnum name="ratio" min="0" max="5" val="1.6"/>
				<attnum name="inertia" val="0.0037"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.9635"/>
			</section>

			<section name="3">
				<attnum name="ratio" min="0" max="5" val="1.5"/>
				<attnum name="inertia" val="0.0048"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.9707"/>
			</section>

			<section name="4">
				<attnum name="ratio" min="0" max="5" val="1.4"/>
				<attnum name="inertia" val="0.0064"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.975"/>
			</section>

			<section name="5">
				<attnum name="ratio" min="0" max="5" val="1.35"/>
				<attnum name="inertia" val="0.0107"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.9789"/>
			</section>

			<section name="6">
				<attnum name="ratio" min="0" max="5" val="1.3"/>
				<attnum name="inertia" val="0.0150"/>
				<attnum name="efficiency" min="0.9" max="1.0" val="0.979"/>
			</section>
		</section>
	</section>

	<section name="Drivetrain">
		<!-- allowed value RWD,4WD -->
		<attstr name="type" in="RWD,4WD,FWD" val="FWD"/>

		<!-- drive shaft inertia -->
		<attnum name="inertia" unit="kg.m2" val="0.0091"/>
	</section>

	<section name="Steer">
		<attnum name="steer lock" unit="deg" min="10" max="55" val="30"/>
		<attnum name="max steer speed" unit="deg/s" min="60" max="720" val="360"/>
	</section>

	<section name="Brake System">
		<attnum name="front-rear brake repartition" min="0.3" max="0.7" val="0.55"/>
		<attnum name="max pressure" unit="kPa" min="100" max="40000" val="20000"/>
		<attnum name="emergency brake pressure" unit="kPa" min="0" max="10000" val="5000"/>
	</section>

	<section name="Front Axle">
		<attnum name="xpos" min="0.5" max="2.5" val="1.15"/>
		<attnum name="inertia" unit="kg.m2" val="0.0056"/>
	</section>

	<section name="Rear Axle">
		<attnum name="xpos" min="-2.5" max="-0.5" val="-1.65"/>
		<attnum name="inertia" unit="kg.m2" val="0.0080"/>
	</section>

	<section name="Front Differential">
		<!-- type of differential: NONE, FREE, LIMITED SLIP, SPOOL -->
		<attstr name="type" in="NONE,FREE,LIMITED SLIP" val="LIMITED SLIP"/>
      <attnum name="inertia" unit="kg.m2" min="0" max="1" val="0.0488" />
      <attnum name="max slip bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="coast max slip bias" min="0" max="100" unit="%" val="10"/>
      <attnum name="locking input torque" min="0" max="800" unit="N.m" val="20"/>
      <attnum name="viscosity factor" min="0" max="1000" unit="%" val="20"/>
      <attnum name="min torque bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="max torque bias" min="0" max="100" unit="%" val="80"/>
      <attnum max="10" min="0" name="ratio" val="3.9" />
      <attnum name="efficiency" val="0.926" />
	</section>

	<section name="Central Differential">
		<attstr name="type" in="NONE,LIMITED SLIP" val="NONE"/>
      <attnum name="inertia" unit="kg.m2" min="0" max="1" val="0.0488" />
      <attnum name="max slip bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="coast max slip bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="locking input torque" min="0" max="800" unit="N.m" val="20"/>
      <attnum name="viscosity factor" min="0" max="100" unit="%" val="20"/>
      <attnum name="min torque bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="max torque bias" min="0" max="100" unit="%" val="80"/>
      <attnum max="10" min="0" name="ratio" val="3.9" />
      <attnum name="efficiency" val="0.926" />
	</section>

	<section name="Rear Differential">
		<!-- type of differential : FREE, LIMITED SLIP -->
		<attstr name="type" in="FREE,LIMITED SLIP" val="NONE"/>
      <attnum name="inertia" unit="kg.m2" min="0" max="1" val="0.0488" />
      <attnum name="max slip bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="coast max slip bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="locking input torque" min="0" max="800" unit="N.m" val="20"/>
      <attnum name="viscosity factor" min="0" max="100" unit="%" val="20"/>
      <attnum name="min torque bias" min="0" max="100" unit="%" val="20"/>
      <attnum name="max torque bias" min="0" max="100" unit="%" val="80"/>
      <attnum max="10" min="0" name="ratio" val="3.9" />
      <attnum name="efficiency" val="0.926" />
	</section>

	<section name="Front Right Wheel">
		<attnum name="ypos" unit="m" min="-1.0" max="0.5" val="-0.8"/>
		<attnum name="rim diameter" unit="in" min="0" max="20" val="19.0"/>
		<attnum name="tire width" unit="mm" min="0" max="255" val="255"/>
		<attnum name="tire height-width ratio" min="0.30" max="1" val=".35"/>
		<attnum name="inertia" unit="kg.m2" min="0.5" max="1.7" val="1.57"/>

		<!-- initial ride height -->
		<attnum name="ride height" unit="mm" min="25" max="280" val="80"/>
		<attnum name="toe" unit="deg" min="-1" max="1" val="0"/>
		<attnum name="camber" min="-90" max="90" unit="deg" val="-2.5"/>

		<!-- Adherence -->
		<attnum name="pressure" unit="kPa" min="130.0" max="320.0" val="200.0"/>
		<attnum name="stiffness" min="15.0" max="25.0" val="25.0"/>
		<attnum name="elasticity factor" min="0.7" max="0.9" val="0.86"/>
		<attnum name="dynamic friction" unit="%" min="25" max="80" val="60"/>
		<attnum name="rolling resistance" min="0.010" max="0.022" val="0.02"/>
		<attnum name="mu" min="1.0" max="1.4" val="1.3"/>

		<!-- tire degradation -->
		<attnum name="cold mu factor" val="0.90"/>
		<attnum name="falloff grip multiplier" val="0.95"/>
	</section>

	<section name="Front Left Wheel">
		<attnum name="ypos" unit="m" min="-0.5" max="1.0" val="0.8"/>
		<attnum name="rim diameter" unit="in" min="0" max="20" val="19.0"/>
		<attnum name="tire width" unit="mm" min="0" max="255" val="255"/>
		<attnum name="tire height-width ratio" min="0.30" max="1" val=".35"/>
		<attnum name="inertia" unit="kg.m2" min="0.5" max="1.7" val="1.57"/>

		<!-- initial ride height -->
		<attnum name="ride height" unit="mm" min="25" max="280" val="80"/>
		<attnum name="toe" unit="deg" min="-1" max="1" val="0"/>
		<attnum name="camber" min="-90" max="90" unit="deg" val="-2.5"/>

		<!-- Adherence -->
		<attnum name="pressure" unit="kPa" min="130.0" max="320.0" val="200.0"/>
		<attnum name="stiffness" min="15.0" max="25.0" val="25.0"/>
		<attnum name="elasticity factor" min="0.7" max="0.9" val="0.86"/>
		<attnum name="dynamic friction" unit="%" min="25" max="80" val="60"/>
		<attnum name="rolling resistance" min="0.010" max="0.022" val="0.02"/>
		<attnum name="mu" min="1.0" max="1.4" val="1.3"/>

		<!-- tire degradation -->
		<attnum name="cold mu factor" val="0.90"/>
		<attnum name="falloff grip multiplier" val="0.95"/>
	</section>

	<section name="Rear Right Wheel">
		<attnum name="ypos" unit="m" min="-1.0" max="0.5" val="-0.8"/>
		<attnum name="rim diameter" unit="in" min="8" max="20" val="19.0"/>
		<attnum name="tire width" unit="mm" min="100" max="330" val="255"/>
		<attnum name="tire height-width ratio" min="0.30" max="1" val="0.3"/>
		<attnum name="inertia" unit="kg.m2" min="0.5" max="2.5" val="1.57"/>

		<!-- initial ride height -->
		<attnum name="ride height" unit="mm" min="25" max="280" val="100"/>
		<attnum name="toe" unit="deg" min="-1" max="1" val="0"/>
		<attnum name="camber" min="-2.5" max="0" unit="deg" val="-2.5"/>

		<!-- Adherence -->
		<attnum name="pressure" unit="kPa" min="130.0" max="320.0" val="200.0"/>
		<attnum name="stiffness" min="15.0" max="25.0" val="25.0"/>
		<attnum name="elasticity factor" min="0.7" max="0.9" val="0.86"/>
		<attnum name="dynamic friction" unit="%" min="25" max="80" val="60"/>
		<attnum name="rolling resistance" min="0.010" max="0.022" val="0.02"/>
		<attnum name="mu" min="1.0" max="1.4" val="1.3"/>

		<!-- tire degradation -->
		<attnum name="cold mu factor" val="0.90"/>
		<attnum name="falloff grip multiplier" val="0.95"/>
	</section>

	<section name="Rear Left Wheel">
		<attnum name="ypos" unit="m" min="0.5" max="1.0" val="0.8"/>
		<attnum name="rim diameter" unit="in" min="8" max="20" val="19.0"/>
		<attnum name="tire width" unit="mm" min="100" max="330" val="255"/>
		<attnum name="tire height-width ratio" min="0.30" max="1" val="0.3"/>
		<attnum name="inertia" unit="kg.m2" min="0.5" max="2.5" val="1.57"/>

		<!-- initial ride height -->
		<attnum name="ride height" unit="mm" min="25" max="280" val="100"/>
		<attnum name="toe" unit="deg" min="-1" max="1" val="0"/>
		<attnum name="camber" min="-2.5" max="0" unit="deg" val="-2.5"/>

		<!-- Adherence -->
		<attnum name="pressure" unit="kPa" min="130.0" max="320.0" val="200.0"/>
		<attnum name="stiffness" min="15.0" max="25.0" val="25.0"/>
		<attnum name="elasticity factor" min="0.7" max="0.9" val="0.86"/>
		<attnum name="dynamic friction" unit="%" min="25" max="80" val="60"/>
		<attnum name="rolling resistance" min="0.010" max="0.022" val="0.02"/>
		<attnum name="mu" min="1.0" max="1.4" val="1.3"/>

		<!-- tire degradation -->
		<attnum name="cold mu factor" val="0.90"/>
		<attnum name="falloff grip multiplier" val="0.95"/>
	</section>

	<section name="Front Anti-Roll Bar">
		<attnum name="spring" unit="kN/m" min="0" max="50" val="10"/>
		<attnum name="suspension course" unit="m" min="0.05" max="0.20" val="0.16"/>
		<attnum name="bellcrank" min="0" max="2" val="1"/>
	</section>

	<section name="Rear Anti-Roll Bar">
		<attnum name="spring" unit="kN/m" min="0" max="50" val="40"/>
		<attnum name="suspension course" unit="m" min="0.05" max="0.20" val="0.20"/>
		<attnum name="bellcrank" min="0" max="2" val="1"/>
	</section>

	<section name="Front Right Suspension">
		<attnum name="spring" unit="kN/m" min="10" max="1000" val="60"/>
		<attnum name="suspension course" unit="m" min="0.12" max="0.56" val="0.16"/>
		<attnum name="bellcrank" min="0" max="2" val="1.0"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0.1" max="100" val="5"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0.1" max="100" val="6"/>
		<attnum name="fast bump" unit="kN/m/s" min="0.1" max="100" val="2"/>
		<attnum name="fast rebound" unit="kN/m/s" min="0.1" max="100" val="1"/>
		<attnum max="0.3" min="0.1" name="bump limit velocity" unit="m/s" val="0.1" />
		<attnum max="0.3" min="0.1" name="rebound limit velocity" unit="m/s" val="0.1" />
	</section>

	<section name="Front Left Suspension">
		<attnum name="spring" unit="kN/m" min="10" max="1000" val="60"/>
		<attnum name="suspension course" unit="m" min="0.12" max="0.56" val="0.16"/>
		<attnum name="bellcrank" min="0" max="2" val="1.0"/>
		<attnum name="packers" unit="mm" min="0" max="10" val="0"/>
		<attnum name="slow bump" unit="kN/m/s" min="0.1" max="100" val="5"/>
		<attnum name="slow rebound" unit="kN/m/s" min="0.1" max="100" val="6"/>
