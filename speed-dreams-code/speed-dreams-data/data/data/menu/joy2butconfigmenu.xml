<!--

	Joystick / gamepad / wheel / pedals calibration screen

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="joy2butconfigmenu">
  <section name="translatable">
    <section name="centerpos">
      <attstr name="text" val="Center the axis and then press a button"/>
      <attstr name="text-spa" val="Centrar el eje y luego presionar un botón"/>
      <attstr name="text-cat" val="Deixeu l'eix en repòs i pitgeu un botó"/>
      <attstr name="text-ru" val="Отцентруйте оси и нажмите кнопку"/>
    </section>
    <section name="apply">
      <attstr name="text" val="Apply the command above and press a button"/>
      <attstr name="text-spa" val="Aplica el comando arriba y pulsa un botón"/>
      <attstr name="text-cat" val="Apliqueu la comanda de dalt i pitgeu un botó"/>
      <attstr name="text-ru" val="Примените команду выше и нажмите кнопку"/>
    </section>
    <section name="complete">
      <attstr name="text" val="Calibration completed"/>
      <attstr name="text-spa" val="Calibración completada"/>
      <attstr name="text-cat" val="Cal·libració finalitzada"/>
      <attstr name="text-ru" val="Калибровка выполнена"/>
    </section>
    <section name="failed">
      <attstr name="text" val="Calibration failed"/>
      <attstr name="text-spa" val="Falló la calibración"/>
      <attstr name="text-cat" val="La cal·libració ha fallat"/>
      <attstr name="text-ru" val="Не удалось откалибровать"/>
    </section>
  </section>
  <section name="dynamic controls">
    <section name="AtobAxisID">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="30"/>
      <attstr name="tip" val=""/>
      <attnum name="x" val="185"/>
      <attnum name="y" val="294"/>
      <attnum name="width" val="150"/>
      <attstr name="h align" val="center"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="medium"/>
    </section>
    <section name="AtobCommandID">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="30"/>
      <attstr name="tip" val=""/>
