    <section name="3">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Joy-to-button configuration"/>
      <attstr name="text-spa" val="Configuración Joy-to-button"/>
      <attstr name="text-cat" val="Configuració de joystick a botons"/>
