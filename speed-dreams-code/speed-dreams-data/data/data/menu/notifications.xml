<!--

	An overlay that is applied to all the menu's

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="notifications">
  <section name="dynamic controls">
    <section name="slide">
      <attstr name="type" val="label"/>
      <attstr name="text" val=""/>
      <!--if we put some initial text here the dynamc text lenght that we will set on runtime will be maximun the lenght of this text. So we leave it empty =  no text limit-->
      <attnum name="x" val="-195"/>
      <attnum name="y" val="57"/>
      <attnum name="width" val="200"/>
      <attstr name="h align" val="left"/>
      <attstr name="color" val="0xff808080"/>
      <attstr name="font" val="small"/>
    </section>
    <section name="slidebg">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="-220"/>
      <attnum name="y" val="2"/>
      <attnum name="width" val="200"/>
      <attnum name="height" val="70"/>
      <attstr name="image" val="data/img/notificationbg.png"/>
    </section>
    <section name="busyicon0">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="5"/>
      <attnum name="y" val="100"/>
      <attnum name="width" val="25"/>
      <attnum name="height" val="21"/>
      <attstr name="image" val="data/img/webserverbusy0.png"/>
    </section>
    <section name="busyicon1">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="5"/>
      <attnum name="y" val="100"/>
      <attnum name="width" val="25"/>
      <attnum name="height" val="21"/>
      <attstr name="image" val="data/img/webserverbusy1.png"/>
    </section>
    <section name="busyicon2">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="5"/>
      <attnum name="y" val="100"/>
      <attnum name="width" val="25"/>
      <attnum name="height" val="21"/>
      <attstr name="image" val="data/img/webserverbusy2.png"/>
    </section>
    <section name="busy">
      <attstr name="type" val="label"/>
      <attstr name="text" val=""/>
      <attnum name="x" val="10"/>
      <attnum name="y" val="10"/>
      <attnum name="width" val="50"/>
      <attstr name="h align" val="left"/>
      <attstr name="color" val="0xff808080"/>
      <attstr name="font" val="small"/>
    </section>
  </section>
  <section name="static controls">
    <section name="1">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="-10"/>
      <attnum name="y" val="375"/>
      <attnum name="width" val="130"/>
      <attnum name="height" val="95"/>
      <attstr name="image" val="data/img/sd-logo-big.png"/>
    </section>
  </section>
</params>
