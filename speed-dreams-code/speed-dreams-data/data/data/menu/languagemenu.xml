<!DOCTYPE params SYSTEM "../../../libs/tgf/params.dtd">

<params name="language" type="param" mode="mw">
	<section name="Languages">
		<section name="1">
			<attstr name="code" val="eng"/>
			<attstr name="name" val="English"/>
		</section>
		<section name="2">
			<attstr name="code" val="cat"/>
			<attstr name="name" val="Català"/>
		</section>
		<section name="3">
			<attstr name="code" val="ru"/>
			<attstr name="name" val="Русский"/>
		</section>
		<section name="4">
			<attstr name="code" val="spa"/>
			<attstr name="name" val="Español"/>
		</section>
		<section name="5">
			<attstr name="code" val="fra"/>
			<attstr name="name" val="Français"/>
		</section>
	</section>
    <section name="dynamic controls">
        <section name="cancel">
            <attstr name="type" val="text button"/>
            <attstr name="show box" val="no"/>
            <attstr name="text" val="Cancel"/>
            <attstr name="text-fra" val="Annuler"/>
            <attstr name="text-spa" val="Cancelar"/>
            <attstr name="text-cat" val="Cancel·lar"/>
            <attstr name="text-ru" val="Отменить"/>
            <attstr name="tip" val="Cancel changes"/>
            <attstr name="tip-fra" val="Ignorer les changements"/>
            <attstr name="tip-spa" val="Cancela los cambios"/>
            <attstr name="tip-cat" val="Cancel·leu els canvis"/>
            <attstr name="tip-ru" val="Отменить изменения"/>
            <attstr name="h align" val="left"/>
            <attnum name="x" val="400"/>
            <attnum name="y" val="44"/>
            <attnum name="width" val="80"/>
            <attstr name="font" val="medium"/>
            <attstr name="color" val="0xa6a6a6"/>
            <attstr name="focused color" val="0xFFFFFF"/>
            <attstr name="pushed color" val="0xFFFFFF"/>
            <attnum name="image x" val="-10"/>
            <attnum name="image y" val="-2"/>
            <attnum name="image width" val="100"/>
            <attnum name="image height" val="30"/>
            <attstr name="focused image" val="data/img/button-left-focused.png"/>
            <attstr name="enabled image" val="data/img/button-left.png"/>
            <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
        </section>
        <section name="apply">
            <attstr name="type" val="text button"/>
            <attstr name="show box" val="no"/>
            <attstr name="text" val="Apply"/>
            <attstr name="text-fra" val="Appliquer"/>
            <attstr name="text-spa" val="Aplicar"/>
            <attstr name="text-cat" val="Aplicar"/>
            <attstr name="text-ru" val="Применить"/>
            <attstr name="tip" val="Accept and save changes"/>
            <attstr name="tip-fra" val="Accepter et sauvegarder les changements"/>
            <attstr name="tip-spa" val="Aceptar y guardar cambios"/>
            <attstr name="tip-cat" val="Apliqueu i deseu els canvis"/>
            <attstr name="tip-ru" val="Принять и сохранить изменения"/>
            <attstr name="h align" val="left"/>
            <attnum name="x" val="500"/>
            <attnum name="y" val="44"/>
            <attnum name="width" val="80"/>
            <attstr name="font" val="medium"/>
            <attstr name="color" val="0xa6a6a6"/>
            <attstr name="focused color" val="0xFFFFFF"/>
            <attstr name="pushed color" val="0xFFFFFF"/>
            <attnum name="image x" val="-10"/>
            <attnum name="image y" val="-2"/>
            <attnum name="image width" val="100"/>
            <attnum name="image height" val="30"/>
            <attstr name="focused image" val="data/img/button-left-focused.png"/>
            <attstr name="enabled image" val="data/img/button-left.png"/>
            <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
        </section>
        <section name="languagecombo">
            <attstr name="type" val="combo box"/>
            <attstr name="tip" val="Choose your language"/>
            <attstr name="tip-fra" val="Choisir sa langue"/>
            <attstr name="tip-spa" val="Elija su idioma"/>
            <attstr name="tip-cat" val="Escolliu el vostre idioma"/>
            <attstr name="tip-ru" val="Выберите язык"/>
            <attnum name="x" val="289"/>
            <attnum name="y" val="225"/>
            <attnum name="width" val="220"/>
            <attnum name="arrows width" val="24"/>
            <attnum name="arrows height" val="24"/>
            <attstr name="color" val="0xFFFFFF"/>
            <attstr name="focused color" val="0xFFFFFF"/>
            <attstr name="pushed color" val="00xFFCC00"/>
            <attstr name="font" val="medium"/>
        </section>
    </section>
    <section name="static controls">
        <section name="1">
            <attstr name="type" val="gallery"/>
            <attstr name="directory" val="data/gallery/"/>
        </section>
        <section name="2">
            <attstr name="type" val="static image"/>
            <attnum name="x" val="-10"/>
            <attnum name="y" val="375"/>
            <attnum name="width" val="130"/>
            <attnum name="height" val="95"/>
            <attstr name="image" val="data/img/sd-logo-big.png"/>
        </section>
        <section name="3">
            <attstr name="type" val="label"/>
            <attstr name="text" val="Language configuration"/>
            <attstr name="text-fra" val="Configuration de la langue"/>
            <attstr name="text-spa" val="Configuración del idioma"/>
            <attstr name="text-cat" val="Configuració de l'idioma"/>
            <attstr name="text-ru" val="Настройки языка"/>
            <attnum name="x" val="300"/>
            <attnum name="y" val="430"/>
            <attnum name="width" val="400"/>
            <attstr name="color" val="0xFFFFFF"/>
            <attstr name="font" val="medium_t"/>
            <attstr name="h align" val="left"/>
            <attstr name="bg image" val="data/img/header-background.png"/>
            <attnum name="bg image padding top" val="15"/>
            <attnum name="bg image padding bottom" val="15"/>
            <attnum name="bg image padding left" val="30"/>
            <attnum name="bg image padding right" val="15"/>
        </section>
        <!-- labels backgrounds -->
        <section name="4">
            <attstr name="type" val="static image"/>
            <attnum name="x" val="70"/>
            <attnum name="y" val="225"/>
            <attnum name="width" val="200"/>
            <attnum name="height" val="24"/>
            <attstr name="image" val="data/img/bg-button-big-normal.png"/>
        </section>
        <!-- labels descriptions -->
        <section name="5">
            <attstr name="type" val="label"/>
            <attnum name="x" val="20"/>
            <attnum name="y" val="230"/>
            <attstr name="text" val="Language:"/>
            <attstr name="text-fra" val="Langue:"/>
            <attstr name="text-spa" val="Idioma:"/>
            <attstr name="text-cat" val="Idioma:"/>
            <attstr name="text-ru" val="Язык:"/>
            <attstr name="h align" val="right"/>
            <attnum name="width" val="220"/>
            <attstr name="font" val="medium_t"/>
            <attstr name="color" val="0xa6a6a6"/>
        </section>
    </section>
</params>
