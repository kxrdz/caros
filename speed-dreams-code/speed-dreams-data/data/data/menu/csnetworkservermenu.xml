<!--

	Network client race menu for specifying the server to connect to

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="csnetworkservermenu">
  <section name="dynamic controls">
    <section name="TitleLabel">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="40"/>
      <attnum name="x" val="361"/>
      <attnum name="y" val="404"/>
      <attstr name="h align" val="right"/>
      <attstr name="font" val="medium"/>
    </section>
    <section name="IPAddrEdit">
      <attstr name="type" val="edit box"/>
      <attstr name="tip" val="IP address of the server to connect to"/>
      <attstr name="tip-ru" val="IP-адрес сервера для подключения"/>
      <attnum name="x" val="271"/>
      <attnum name="y" val="319"/>
      <attnum name="max len" val="16"/>
      <attnum name="width" val="180"/>
      <attstr name="font" val="medium"/>
    </section>
    <section name="PortEdit">
      <attstr name="type" val="edit box"/>
      <attstr name="tip" val="Server port to connect to"/>
      <attstr name="tip-ru" val="Порт сервера для подключения"/>
      <attnum name="x" val="271"/>
      <attnum name="y" val="289"/>
      <attnum name="max len" val="16"/>
      <attnum name="width" val="180"/>
      <attstr name="font" val="medium"/>
    </section>
    <section name="ConnectButton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Connect"/>
      <attstr name="text-fra" val="Connecter"/>
      <attstr name="text-ru" val="Подключиться"/>
      <attstr name="tip" val="Connect to the specified server"/>
      <attstr name="tip-ru" val="Подключиться к указанному серверу"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="435"/>
      <attnum name="y" val="82"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <!-- Back button -->
    <section name="backbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Back"/>
      <attstr name="text-fra" val="Précédent"/>
      <attstr name="text-ru" val="Назад"/>
      <attstr name="tip" val="Cancel changes and get back to the competitors selection menu"/>
      <attstr name="tip-ru" val="Отменить изменения и вернуться к выбору участников"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="278"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <!-- Next button -->
    <section name="nextbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Next"/>
      <attstr name="text-fra" val="Prochain"/>
      <attstr name="text-ru" val="Далее"/>
      <attstr name="tip" val="Apply changes and prepare for the race"/>
      <attstr name="tip-ru" val="Применить изменения и готовиться к гонке"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="435"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
  </section>
  <section name="static controls">
    <section name="1">
      <attstr name="type" val="background image"/>
      <attstr name="image" val="data/img/splash-networkclientconnect.jpg"/>
    </section>
    <section name="2">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="212"/>
      <attnum name="y" val="400"/>
      <attnum name="width" val="450"/>
      <attnum name="height" val="20"/>
      <attstr name="image" val="data/img/head-raceman.png"/>
    </section>
    <section name="3">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="-10"/>
      <attnum name="y" val="375"/>
      <attnum name="width" val="130"/>
      <attnum name="height" val="95"/>
      <attstr name="image" val="data/img/sd-logo-big.png"/>
    </section>
    <section name="4">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Connect to host"/>
      <attstr name="text-ru" val="Подключиться к хосту"/>
      <attnum name="x" val="271"/>
      <attnum name="y" val="404"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="h align" val="left"/>
      <attstr name="font" val="medium"/>
    </section>
    <section name="5">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Server IP Address:"/>
      <attstr name="text-ru" val="IP-адрес сервера:"/>
      <attnum name="x" val="20"/>
      <attnum name="y" val="319"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="h align" val="right"/>
      <attnum name="width" val="220"/>
      <attstr name="font" val="small_t"/>
    </section>
    <section name="6">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Server Port:"/>
      <attstr name="text-ru" val="Порт сервера:"/>
      <attnum name="x" val="20"/>
      <attnum name="y" val="289"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="h align" val="right"/>
      <attnum name="width" val="220"/>
      <attstr name="font" val="small_t"/>
    </section>
  </section>
</params>
