<!--

	Help screen (behind the F1 key in every menu)

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="helpmenu">
  <section name="properties">
    <attnum name="xLeftColumn" val="190"/>
    <attnum name="xRightColumn" val="360"/>
    <attnum name="nameFieldWidth" val="80"/>
    <attnum name="yTopLine" val="380"/>
    <attnum name="lineShift" val="13"/>
  </section>
  <section name="template controls">
    <section name="keyName">
      <attstr name="type" val="label"/>
      <attstr name="tip" val="Key name"/>
      <attstr name="tip-ru" val="Название кнопки"/>
      <attnum name="width" val="70"/>
      <attstr name="h align" val="right"/>
      <attstr name="font" val="small_c"/>
      <attstr name="color" val="0xFFCC00"/>
      <attstr name="focused color" val="0xFFCC00"/>
    </section>
    <section name="keyDesc">
      <attstr name="type" val="label"/>
      <attstr name="tip" val="Key description"/>
      <attstr name="tip-ru" val="Описание кнопки"/>
      <attstr name="h align" val="left"/>
      <attstr name="font" val="small_t"/>
      <attstr name="color" val="0xFFFFFF"/>
    </section>
  </section>
  <section name="dynamic controls">
    <!-- Back button -->
    <section name="backbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Back"/>
      <attstr name="text-fra" val="Retour"/>
      <attstr name="text-ru" val="Назад"/>
      <attstr name="tip" val="Return to previous menu"/>
      <attstr name="tip-ru" val="Вернуться к предыдущему меню"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="280"/>
      <attnum name="y" val="50"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <!-- Version label -->
    <section name="versionlabel">
      <attstr name="type" val="label"/>
      <attstr name="tip" val="Actual version of the game"/>
      <attstr name="tip-ru" val="Актуальная версия игры"/>
      <attnum name="x" val="532"/>
      <attnum name="y" val="25"/>
      <attnum name="width" val="100"/>
      <attstr name="h align" val="right"/>
      <attstr name="color" val="0x00CCFF"/>
      <attstr name="font" val="small_t"/>
    </section>
  </section>
  <section name="static controls">
    <section name="1">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="-10"/>
      <attnum name="y" val="305"/>
      <attnum name="width" val="195"/>
      <attnum name="height" val="130"/>
      <attstr name="image" val="data/img/sd-logo-big.png"/>
    </section>
    <section name="2">
      <attstr name="type" val="gallery"/>
      <attstr name="directory" val="data/gallery/"/>
    </section>
    <section name="3">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Help screen"/>
      <attstr name="text-ru" val="Справка"/>
      <attnum name="x" val="300"/>
      <attnum name="y" val="430"/>
      <attnum name="width" val="400"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="medium_t"/>
      <attstr name="h align" val="left"/>
      <attstr name="bg image" val="data/img/header-background.png"/>
      <attnum name="bg image padding top" val="15"/>
      <attnum name="bg image padding bottom" val="15"/>
      <attnum name="bg image padding left" val="30"/>
      <attnum name="bg image padding right" val="15"/>
    </section>
  </section>
  <section name="music">
    <attstr name="music file" val="data/music/qualifications.ogg"/>
  </section>
</params>
