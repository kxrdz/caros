    </section>
    <section name="2">
      <attstr name="type" val="gallery"/>
      <attstr name="directory" val="data/gallery/"/>
    </section>
    <section name="3">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Select a racing mode"/>
      <attstr name="text-fra" val="Sélectionner un type de course"/>
      <attstr name="text-spa" val="Seleccione un modo de carrera"/>
      <attstr name="text-cat" val="Seleccioneu un mode de cursa"/>
