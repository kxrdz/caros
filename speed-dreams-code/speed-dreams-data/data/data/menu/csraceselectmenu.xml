<!--

	Race mode/type selection menu

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="optionsmenu">
  <section name="dynamic controls">
    <!--

	Beware with the control names :
	* "(race manager type)Button"
	* "(race manager type)Combo"
	where (race manager type) comes from (racemanager).xml, "type" field in the "Header".

	-->
    <section name="PracticeButton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Practice"/>
      <attstr name="text-fra" val="Pratique"/>
      <attstr name="text-spa" val="Práctica"/>
      <attstr name="text-cat" val="Pràctica"/>
      <attstr name="text-ru" val="Практика"/>
      <attstr name="tip" val="A free practice session for one player on one track"/>
      <attstr name="tip-fra" val="Une session de pratique libre à un seul joueur sur un circuit choisi."/>
      <attstr name="tip-spa" val="Una sesión de entrenamientos libres para un jugador en un circuito"/>
      <attstr name="tip-cat" val="Una sessió de pràctica lliure amb un jugador a un circuit"/>
      <attstr name="tip-ru" val="Свободная сессия для одного игрока на одной трассе"/>
      <attnum name="x" val="200"/>
      <attnum name="y" val="325"/>
      <attnum name="width" val="320"/>
      <attstr name="h align" val="left"/>
      <attstr name="font" val="big"/>
      <attstr name="color" val="0xa6a6a6"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-48"/>
      <attnum name="image y" val="0"/>
      <attnum name="image width" val="320"/>
      <attnum name="image height" val="34"/>
      <attstr name="focused image" val="data/img/bg-button-big-focused.png"/>
      <attstr name="enabled image" val="data/img/bg-button-big.png"/>
      <attstr name="pushed image" val="data/img/bg-button-big-pushed.png"/>
    </section>
    <!-- second button for STANDARDGAME only -->
