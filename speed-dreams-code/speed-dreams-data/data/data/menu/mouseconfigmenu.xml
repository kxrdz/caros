<!--

	Mouse calibration menu

-->
<!DOCTYPE params SYSTEM "../tgf/params.dtd">
<params name="mouseconfigmenu">
  <section name="dynamic controls">
    <section name="instructionlabel">
      <attstr name="type" val="label"/>
      <attnum name="max len" val="60"/>
      <attnum name="x" val="170"/>
      <attnum name="y" val="100"/>
      <attnum name="width" val="300"/>
      <attstr name="h align" val="center"/>
      <attstr name="color" val="0x00CCFF"/>
      <attstr name="font" val="small_t"/>
    </section>
    <section name="cancelbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Cancel"/>
      <attstr name="text-fra" val="Annuler"/>
      <attstr name="text-ru" val="Отменить"/>
      <attstr name="tip" val="Cancel changes"/>
      <attstr name="tip-ru" val="Отменить изменения"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="130"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <section name="resetbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Reset"/>
      <attstr name="text-fra" val="Réinitialiser"/>
      <attstr name="text-ru" val="Сбросить"/>
      <attstr name="tip" val="Restart calibration procedure"/>
      <attstr name="tip-ru" val="Перезапустить процедуру калибровки"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="288"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <section name="nextbutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Next"/>
      <attstr name="text-fra" val="Prochain"/>
      <attstr name="text-ru" val="След."/>
      <attstr name="tip" val="Proceed to the next calibration page"/>
      <attstr name="tip-ru" val="Перейти к следующей странице калибровки"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="460"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
    <section name="donebutton">
      <attstr name="type" val="text button"/>
      <attstr name="show box" val="no"/>
      <attstr name="text" val="Done"/>
      <attstr name="text-fra" val="Terminé"/>
      <attstr name="text-ru" val="Выполнено"/>
      <attstr name="tip" val="Done, return to control config"/>
      <attstr name="tip-ru" val="Выполнено, вернуться к настройке управления"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="460"/>
      <attnum name="y" val="44"/>
      <attnum name="width" val="120"/>
      <attstr name="font" val="medium"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="focused color" val="0xFFFFFF"/>
      <attstr name="pushed color" val="0xFFFFFF"/>
      <attnum name="image x" val="-10"/>
      <attnum name="image y" val="4"/>
      <attnum name="image width" val="60"/>
      <attnum name="image height" val="16"/>
      <attstr name="focused image" val="data/img/button-left-focused.png"/>
      <attstr name="enabled image" val="data/img/button-left.png"/>
      <attstr name="pushed image" val="data/img/button-left-pushed.png"/>
    </section>
  </section>
  <section name="static controls">
    <section name="1">
      <attstr name="type" val="background image"/>
      <attstr name="image" val="data/img/splash-mousecal.jpg"/>
    </section>
    <section name="2">
      <attstr name="type" val="static image"/>
      <attnum name="x" val="-10"/>
      <attnum name="y" val="375"/>
      <attnum name="width" val="130"/>
      <attnum name="height" val="95"/>
      <attstr name="image" val="data/img/sd-logo-big.png"/>
    </section>
    <section name="3">
      <attstr name="type" val="label"/>
      <attstr name="text" val="Mouse configuration"/>
      <attstr name="text-fra" val="Configuration de la souris"/>
      <attstr name="text-ru" val="Настройки мыши"/>
      <attnum name="x" val="300"/>
      <attnum name="y" val="430"/>
      <attnum name="width" val="400"/>
      <attstr name="color" val="0xFFFFFF"/>
      <attstr name="font" val="medium_t"/>
      <attstr name="h align" val="left"/>
      <attstr name="bg image" val="data/img/header-background.png"/>
      <attnum name="bg image padding top" val="15"/>
      <attnum name="bg image padding bottom" val="15"/>
      <attnum name="bg image padding left" val="30"/>
      <attnum name="bg image padding right" val="15"/>
    </section>
  </section>
</params>
