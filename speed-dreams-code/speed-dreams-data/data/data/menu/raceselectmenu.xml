      <attstr name="text-cat" val="Cursa ràpida"/>
      <attstr name="tip" val="A race on one track, with no qualifying session"/>
      <attstr name="tip-spa" val="Una carrera en un circuito, sin sesión de clasificación"/>
      <attstr name="tip-cat" val="Una cursa a un circuit, sense sessió de qualificació"/>
      <attstr name="h align" val="left"/>
      <attnum name="x" val="260"/>
      <attnum name="y" val="290"/>
      <attnum name="width" val="320"/>
      <attstr name="font" val="big"/>
