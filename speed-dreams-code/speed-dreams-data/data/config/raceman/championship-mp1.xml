    <section name="13">
      <attstr name="name" val="prenzlau"/>
      <attstr name="category" val="road"/>
    </section>

    <section name="14">
      <attstr name="name" val="auriac"/>
      <attstr name="category" val="road"/>
    </section>

    <section name="15">
      <attstr name="name" val="salty"/>
      <attstr name="category" val="road"/>
    </section>

    <section name="16">
      <attstr name="name" val="newton"/>
      <attstr name="category" val="speedway"/>
    </section>

	<section name="17">
